            const addedToDebt = inv.totalAmount - inv.paidAmount;
            const invoiceNotes = inv.notes || "---";

            const status = addedToDebt <= 0 ? "مدفوعة بالكامل" : (inv.paidAmount > 0 ? "دفع جزئي" : "آجل (دين كامل)");
            const statusColor = addedToDebt <= 0 ? "bg-emerald-50 text-emerald-600" : (inv.paidAmount > 0 ? "bg-blue-50 text-blue-600" : "bg-rose-50 text-rose-600");

            return (
              <tr key={inv.id} className="hover:bg-gray-50 transition">
                <td className="p-4 font-bold text-gray-400 font-mono text-xs">#{inv.id.slice(-6).toUpperCase()}</td>
                <td className="p-4">
