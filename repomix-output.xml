              );
            })
          )}
        </tbody>
      </table>
    </div>
  </div>
);

// 3. مكون نافذة الإضافة/التعديل
export const InventoryModal = ({ state, dispatch, onSave }: any) => {
  return (
    <Modal 
      isOpen={state.modals.addEdit} 
