generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  WORKER
}

// ================= الأدوار والمستخدمين =================
model User {
  id            String              @id @default(cuid())
  name          String
  phone         String              @unique
  password      String
  role          Role                @default(WORKER) // ADMIN أو WORKER
  baseSalary    Float               @default(0)        
  createdAt     DateTime            @default(now())

  //  (Relation Names)
  tickets       Ticket[]            @relation("WorkerTickets")
  trialItems    TrialItem[]         @relation("WorkerTrials")
  transactions  WorkerTransaction[]
}

// ================= المخزون والقطع =================
model SparePart {
  id            String         @id @default(cuid())
  name          String
  quantity      Int            @default(0)
  averageCost   Float          @default(0.0)
  sellingPrice  Float          @default(0.0)
  lowStockAlert Int            @default(5)
  imageUrl      String?

  //  (Relation Names)
  ticketParts   TicketPart[]
  trialItems    TrialItem[]
  purchaseItems PurchaseItem[]
}

model Compressor {
  id             String      @id @default(cuid())
  serialNumber   String?     
  modelName      String
  productionCost Float       @default(0.0)
  sellingPrice   Float       @default(0.0)
  status         String      @default("READY")
  imageUrl       String?     
  createdAt      DateTime    @default(now()) 
  trialItems     TrialItem[]
}

// ================= القطع التجريبية =================
enum TrialStatus {
  ACTIVE
  RETURNED
  EXPIRED
}

model TrialItem {
  id             String      @id @default(cuid())
  notes          String?
  status         TrialStatus @default(ACTIVE)
  givenAt        DateTime    @default(now())
  expectedReturn DateTime?
  returnedAt     DateTime?

  sparePartId    String?
  sparePart      SparePart?  @relation(fields: [sparePartId], references: [id])
  qty            Int         @default(1)

  compressorId   String?
  compressor     Compressor? @relation(fields: [compressorId], references: [id])

  // "WorkerTrials"
  workerId       String?
  worker         User?       @relation("WorkerTrials", fields: [workerId], references: [id])
  
  ticketId       String?
  ticket         Ticket?     @relation(fields: [ticketId], references: [id])
}

// ================= نظام التذاكر =================
enum TicketStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELED
}

model Ticket {
  id               String       @id @default(cuid())
  customerName     String
  customerPhone    String
  compressorModel  String?
  issueDescription String?
  invoiceImageUrl  String?      
  advancePayment   Float        @default(0.0)
  discount         Float        @default(0.0)
  status           TicketStatus @default(OPEN)
  laborCost        Float        @default(0.0)
  commission       Float        @default(0.0)
  totalCost        Float        @default(0.0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // "WorkerTickets"
  workerId         String?
  worker           User?        @relation("WorkerTickets", fields: [workerId], references: [id])
  
  partsUsed        TicketPart[]
  payments         Payment[]    
  trialItems       TrialItem[]
  expenses         Expense[]
}

// ================= الدفعات والمعاملات =================
model Payment {
  id        String   @id @default(cuid())
  amount    Float
  notes     String?
  createdAt DateTime @default(now())

  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model TicketPart {
  id          String    @id @default(cuid())
  ticketId    String
  ticket      Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sparePartId String
  sparePart   SparePart @relation(fields: [sparePartId], references: [id])
  quantity    Int
  priceAtTime Float
}


enum TypesWorkerTransaction {
  ADVANCE
  STAKE
  BONUS
  PAYOUT
}
model WorkerTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Float    
  type        TypesWorkerTransaction   
  description String?  
  date        DateTime @default(now())
}

// ================= المشتريات والموردين =================
model Supplier {
  id        String            @id @default(cuid())
  name      String
  phone     String?
  totalDebt Float             @default(0.0)
  invoices  PurchaseInvoice[]

  payments    SupplierPayment[] 
}

model SupplierPayment {
  id         String   @id @default(cuid())
  amount     Float
  date       DateTime @default(now())
  notes      String?
  
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}



model PurchaseInvoice {
  id          String         @id @default(cuid())
  supplierId  String
  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  totalAmount Float
  paidAmount  Float          @default(0.0)
  date        DateTime       @default(now())
  notes       String?
  items       PurchaseItem[]
}

model PurchaseItem {
  id          String          @id @default(cuid())
  invoiceId   String
  invoice     PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sparePartId String
  sparePart   SparePart       @relation(fields: [sparePartId], references: [id])
  quantity    Int
  unitCost    Float
  notes       String?
}

// ================= المصاريف التشغيلية =================
enum ExpenseCategory {
  STANDARD
  EXTRA
}

model Expense {
  id       String          @id @default(cuid())
  title    String
  amount   Float
  category ExpenseCategory @default(STANDARD)
  date     DateTime        @default(now())
  notes    String?

  ticketId String?
  ticket   Ticket?         @relation(fields: [ticketId], references: [id])
}



